<!DOCTYPE html>

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Football Inventory</title>

```
<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:Arial, Helvetica, sans-serif;
    }

    body{
        background:#f5f7fa;
        color:#222;
    }

    nav{
        background:#111827;
        padding:1rem 2rem;
        display:flex;
        justify-content:space-between;
        align-items:center;
    }

    nav form input{
        border: 2px solid black;
        border-radius: 7px;
        padding: 10px;
    }
    nav form button{
        padding: 10px;
        border-radius: 7px;
        background-color: #60a5fa;
    }

    .logo{
        color:white;
        font-size:1.4rem;
        font-weight:bold;
    }

    .nav-links{
        display:flex;
        gap:1rem;
    }


    .nav-links a{
        color:white;
        text-decoration:none;
        transition:0.2s;
    }

    .nav-links a:hover{
        color:#60a5fa;
    }

    .container{
        width:90%;
        max-width:1200px;
        margin:2rem auto;
    }

    .header{
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:2rem;
    }

    .btn{
        background:#2563eb;
        color:white;
        text-decoration:none;
        padding:0.8rem 1rem;
        border-radius:8px;
    }

    .products-grid{
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
        gap:1.5rem;
    }

    .card{
        background:white;
        padding:1.5rem;
        border-radius:12px;
        box-shadow:0 4px 10px rgba(0,0,0,0.08);
    }

    .card h3{
        margin-bottom:1rem;
    }

    .price{
        color:#2563eb;
        font-weight:bold;
        margin-top:1rem;
    }

    .empty{
        text-align:center;
        padding:2rem;
        background:white;
        border-radius:12px;
    }
    .btn-eliminar button{
        border: 2px solid red;
        border-radius: 12px;
        background-color: red;
        color: white;
        padding: 1vh;
        margin-top: 1vh;
        transition: 
        200ms box-shadow ease-in 200ms,
        200ms transform ease-in 200ms;
    }

    .btn-editar button{
        border: 2px solid ;
        border-radius: 12px;
        background-color: #2563eb;
        color: white;
        padding: 1vh;
        margin-top: 1vh;
        transition: 
        200ms box-shadow ease-in 200ms,
        200ms transform ease-in 200ms;
    }

    .container-btns{
        display: flex;
        gap: 2vh;
    }

    .btn-eliminar button:hover{
        box-shadow: 2px 2px 2px red;
        transform: translateY(1vh);
    }

    .btn-editar button:hover{
        box-shadow: 2px 2px 2px #60a5fa;
        transform: translateY(1vh);
    }


</style>
```

</head>
<body>

```
<nav>
    <div class="logo">
        Football Inventory
    </div>

    <div class="nav-links">
        <% links.forEach(link => { %>
            <a href="<%= link.href %>">
                <%= link.text %>
            </a>
        <% }) %>
    </div>

    <form action="/products/search" method="GET"> 
        <input type="text" name="query" placeholder="Buscar producto..." >
         <button type="submit"> 🔍 </button> 
    </form>
</nav>

<div class="container">

    <div class="header">
        <h1>Inventario de Equipaciones</h1>

        <a href="/products/new" class="btn">
            + Nueva Equipación
        </a>
    </div>

    <% if(products.length === 0){ %>

        <div class="empty">
            <h2>No hay productos registrados</h2>
        </div>

    <% } else { %>

        <div class="products-grid">

            <% products.forEach(product => { %>

                <div class="card">

                    <h3><%= product.nombre %></h3>

                    <p>
                        Categoría:
                        <strong><%= product.category_id %></strong>
                    </p>

                    <p class="price">
                        $<%= product.precio %>
                    </p>
                    
                    <div class="container-btns">
                        <form class="btn-eliminar" action="/products/<%= product.id_producto %>/delete" method="post">
                        <button type="submit">DELETE</button>
                        </form>

                        <form class="btn-editar" action="/products/<%= product.id_producto %>/update" method="get">
                        <button type="submit">UPDATE</button>
                        </form>
                    </div>
                </div>

            <% }) %>

        </div>

    <% } %>

</div>
```

</body>
</html>
