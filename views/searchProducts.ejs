<!DOCTYPE html>

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Buscar Productos</title>

```
<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:Arial, Helvetica, sans-serif;
    }

    body{
        background:#f5f7fa;
        color:#222;
    }

    .container{
        width:90%;
        max-width:1200px;
        margin:2rem auto;
    }

    h1{
        margin-bottom:2rem;
    }

    .back-btn{
        display:inline-block;
        margin-bottom:2rem;
        text-decoration:none;
        background:#2563eb;
        color:white;
        padding:0.8rem 1rem;
        border-radius:8px;
    }

    .products-grid{
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
        gap:1.5rem;
    }

    .card{
        background:white;
        padding:1.5rem;
        border-radius:12px;
        box-shadow:0 4px 10px rgba(0,0,0,0.08);
    }

    .card h3{
        margin-bottom:1rem;
    }

    .price{
        color:#2563eb;
        font-weight:bold;
        margin-top:1rem;
    }

    .empty{
        text-align:center;
        background:white;
        padding:2rem;
        border-radius:12px;
    }
</style>
```

</head>
<body>

<div class="container">

```
<a href="/" class="back-btn">
    ← Volver al inventario
</a>

<h1>Resultados de búsqueda</h1>

<% if(productosFiltrado.length === 0){ %>

    <div class="empty">
        <h2>No se encontraron productos</h2>
    </div>

<% } else { %>

    <div class="products-grid">

        <% productosFiltrado.forEach(product => { %>

            <div class="card">

                <h3><%= product.nombre %></h3>

                <p>
                    Categoría:
                    <strong><%= product.category_id %></strong>
                </p>

                <p class="price">
                    $<%= product.precio %>
                </p>

            </div>

        <% }) %>

    </div>

<% } %>
```

</div>

</body>
</html>
