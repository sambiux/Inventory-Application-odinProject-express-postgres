<!-- views/updateUser.ejs -->
<!DOCTYPE html>
<html>
  <head>
    <title>Update Product</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap');

        *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Arial, Helvetica, sans-serif;
    }

    body{
        background:#f4f6f9;
        min-height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
        padding:2rem;
    }

    .container{
        background:white;
        width:100%;
        max-width:600px;
        padding:2rem;
        border-radius:16px;
        box-shadow:0 10px 25px rgba(0,0,0,.1);
    }

    h1{
        text-align:center;
        margin-bottom:2rem;
        color:#1f2937;
    }

    .form-group{
        margin-bottom:1.2rem;
    }

    label{
        display:block;
        margin-bottom:.4rem;
        font-weight:bold;
        color:#374151;
    }

    input,
    select{
        width:100%;
        padding:.8rem;
        border:1px solid #d1d5db;
        border-radius:8px;
        font-size:1rem;
    }

    input:focus,
    select:focus{
        outline:none;
        border-color:#2563eb;
    }

    .btn{
        width:100%;
        border:none;
        background:#2563eb;
        color:white;
        padding:1rem;
        border-radius:8px;
        font-size:1rem;
        cursor:pointer;
        transition:.2s;
    }

    .btn:hover{
        background:#1d4ed8;
    }

    .back-link{
        display:block;
        text-align:center;
        margin-top:1rem;
        text-decoration:none;
        color:#2563eb;
    }

        .back-link:hover{
            text-decoration:underline;
        }
        body{
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 10vh;
          color: #2563eb;
          width: 100%;
          overflow: hidden;
          font-family: "Archivo Black", sans-serif;
          font-weight: 400;
          font-style: normal;
       }
        form{
          display: flex;
          flex-direction: column;
          gap: 2vh;
          border: 2px solid gray;
          border-radius: 12px;
          padding: 9vh;
          box-shadow: 2px 2px 2px blue;
        }

        form input{
          border-radius: 7px;
        }

        form button{
          border: 2px solid black;
          border-radius: 6px;
          padding: 7px;
          background-color: #2563eb;
          color: white;
          font-family: "Archivo Black", sans-serif;
          transition:
            200ms transform ease-in 200ms
          ;
        }

        form button:hover{
          transform: translateY(7px);
        }
    </style>
  </head>
<body>
  <h1>Update Product</h1>
  <form action="/products/<%= product.id %>/update" method="POST">
    <label for="nombre">Name price</label>
    <input type="text" name="nombre" required>
    <label for="precio">Price</label>
    <input type="text" name="precio" required>
    <button type="submit">Update User</button>
  </form>
  <a href="/">Back to home</a>
</body>
</html>